# App
APP_ENV=production
LOG_LEVEL=INFO
PORT=5002

# Model provider key (required for triage, voice, and photo analysis)
OPENAI_API_KEY=

# Google Maps API key (required for "Find Nearby Vets" feature)
# 1. Get a key at: https://console.cloud.google.com/apis/credentials
# 2. Enable "Places API (New)" at: https://console.cloud.google.com/apis/library/places.googleapis.com
GOOGLE_MAPS_API_KEY=

# Password Protection (HTTP Basic Auth)
# Set AUTH_ENABLED=true to require username/password to access the site
AUTH_ENABLED=true
AUTH_USERNAME=MMAI 891
AUTH_PASSWORD=P0CD3mo123!

# Default model routing
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# Webhook Automation (optional — post-intake actions)
# Set to any webhook receiver URL (Slack, Zapier, custom endpoint, etc.)
# Leave blank to disable webhook firing.
# N8N_WEBHOOK_URL=http://localhost:5678/webhook/petcare

# Authentication (set via environment variables — NEVER hardcode credentials)
# Set AUTH_ENABLED=true on Render to enable password protection
AUTH_ENABLED=false
AUTH_USERNAME=
AUTH_PASSWORD=

# Runtime
REQUEST_TIMEOUT_SECONDS=60
MAX_RETRIES=2
