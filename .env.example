# App
APP_ENV=development
LOG_LEVEL=INFO
PORT=5002

# Model provider key (required for triage, voice, and photo analysis)
OPENAI_API_KEY=

# Google Maps API key (optional — enables "Find Nearby Vets" feature)
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable: Places API, Places API (New)
# GOOGLE_MAPS_API_KEY=

# Default model routing
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# Webhook Automation (optional — post-intake actions)
# Set to any webhook receiver URL (Slack, Zapier, custom endpoint, etc.)
# Leave blank to disable webhook firing.
# N8N_WEBHOOK_URL=http://localhost:5678/webhook/petcare

# Runtime
REQUEST_TIMEOUT_SECONDS=60
MAX_RETRIES=2
