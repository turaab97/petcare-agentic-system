# App
APP_ENV=development
LOG_LEVEL=INFO
PORT=5002

# LangSmith / LangGraph tracing (optional but recommended)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=petcare-triage-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Model provider keys (fill only what you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Default model routing
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4.1-mini

# n8n Workflow Automation (actions layer)
# If using docker-compose, this is set automatically.
# If using n8n Cloud, paste your webhook URL here.
N8N_WEBHOOK_URL=http://localhost:5678/webhook/petcare

# Runtime
REQUEST_TIMEOUT_SECONDS=60
MAX_RETRIES=2
